---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Farida.estate - Institutional-grade fractional real estate investment in Egypt. Start building your portfolio today." } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Google Fonts: Inter (Sans) and Playfair Display (Serif) -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
		
		<title>{title}</title>
	</head>
	<body class="bg-farida-surface text-slate-800 antialiased selection:bg-farida-accent selection:text-white">
		<slot />
	</body>
</html>
