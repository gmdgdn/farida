---
// Hero.astro
---
<section class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden bg-slate-900">
  
  <!-- Premium Background Image with Overlay -->
  <div class="absolute inset-0">
    <img src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?ixlib=rb-4.0.3&auto=format&fit=crop&w=2000&q=80" alt="Luxury Real Estate" class="w-full h-full object-cover opacity-30 mix-blend-overlay" />
    <div class="absolute inset-0 bg-gradient-to-r from-slate-900 via-slate-900/95 to-slate-900/50"></div>
  </div>

  <div class="absolute top-0 right-0 -translate-y-12 translate-x-1/3 w-[800px] h-[800px] bg-blue-500 rounded-full blur-[150px] opacity-20 pointer-events-none"></div>
  <div class="absolute top-[20%] left-[-10%] w-[500px] h-[500px] bg-emerald-500 rounded-full blur-[120px] opacity-20 pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      
      <!-- Left Content: Value Proposition -->
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-slate-800/80 border border-slate-700 backdrop-blur-md text-emerald-400 text-sm font-medium mb-8">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
          </span>
          Regulated by FRA Egypt
        </div>
        
        <h1 class="text-5xl lg:text-7xl font-serif font-bold text-white tracking-tight leading-[1.1] mb-6">
          Own Real Estate Shares <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-emerald-400 font-serif italic">With Ease.</span>
        </h1>
        
        <p class="text-lg text-slate-300 mb-10 leading-relaxed max-w-xl font-light">
          Build a resilient portfolio with institutional-grade property in Egypt. Access monthly cash flows and capital appreciation without the landlord headaches.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/invest" class="inline-flex justify-center items-center px-8 py-4 border border-transparent text-base font-semibold rounded-lg text-slate-900 bg-emerald-400 hover:bg-emerald-300 shadow-[0_0_20px_rgba(16,185,129,0.3)] hover:shadow-[0_0_30px_rgba(16,185,129,0.5)] hover:-translate-y-0.5 transition-all duration-300">
            View Live Properties
          </a>
          <a href="/how-it-works" class="inline-flex justify-center items-center px-8 py-4 border border-slate-600 text-base font-medium rounded-lg text-white hover:bg-slate-800 backdrop-blur-sm transition-all duration-300">
            How it works
          </a>
        </div>
        
        <!-- Trust Metrics -->
        <div class="mt-12 pt-8 border-t border-slate-700 grid grid-cols-2 sm:grid-cols-3 gap-6">
          <div>
            <p class="text-4xl font-serif font-bold text-white">EGP 1B+</p>
            <p class="text-sm font-medium text-slate-400 mt-2 uppercase tracking-wide">Total Sales</p>
          </div>
          <div>
            <p class="text-4xl font-serif font-bold text-white">9,000+</p>
            <p class="text-sm font-medium text-slate-400 mt-2 uppercase tracking-wide">Investors</p>
          </div>
          <div class="hidden sm:block">
            <p class="text-4xl font-serif font-bold text-emerald-400">12%</p>
            <p class="text-sm font-medium text-slate-400 mt-2 uppercase tracking-wide">Avg. Target Yield</p>
          </div>
        </div>
      </div>

      <!-- Right Content: Interactive Graphic / SVG -->
      <div class="relative lg:ml-10">
        <div class="relative rounded-2xl bg-white/10 backdrop-blur-md shadow-2xl border border-white/20 p-2 overflow-hidden aspect-[4/3] flex items-center justify-center group">
            <div class="absolute inset-0 bg-gradient-to-tr from-slate-900/50 to-transparent"></div>
            
            <!-- Contextual UI Mockup element -->
            <div class="relative z-10 w-full max-w-sm bg-slate-900 rounded-xl shadow-2xl border border-slate-700 overflow-hidden transform transition-transform duration-500 group-hover:scale-[1.02]">
                <div class="p-5 border-b border-slate-800 flex items-center justify-between bg-slate-800/50">
                    <div>
                        <p class="text-xs text-slate-400 font-medium tracking-wider mb-1">YOUR PORTFOLIO</p>
                        <p class="text-2xl font-serif font-bold text-white">EGP 245,000</p>
                    </div>
                    <div class="text-right">
                        <p class="text-sm text-emerald-400 font-medium flex items-center justify-end gap-1 mb-1">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
                            +12.4%
                        </p>
                        <p class="text-sm font-semibold text-slate-300">EGP 30,380</p>
                    </div>
                </div>
                <!-- Dynamic SVG Chart Animation -> "Nano Banana / Gemini 3.1 Standard" -->
                <div class="p-6 h-56 flex items-end justify-between bg-slate-900/80 relative overflow-hidden" id="hero-chart-container">
                    
                    <!-- SVG Graph Layer -->
                    <svg viewBox="0 0 400 200" class="absolute inset-0 w-full h-full preserve-3d" style="filter: drop-shadow(0 10px 8px rgba(16, 185, 129, 0.2));">
                        <defs>
                            <linearGradient id="gradientLine" x1="0" y1="0" x2="1" y2="0">
                                <stop offset="0%" stop-color="#3B82F6" />
                                <stop offset="50%" stop-color="#10B981" />
                                <stop offset="100%" stop-color="#34D399" />
                            </linearGradient>
                            <linearGradient id="gradientFill" x1="0" y1="0" x2="0" y2="1">
                                <stop offset="0%" stop-color="#10B981" stop-opacity="0.3" />
                                <stop offset="100%" stop-color="#10B981" stop-opacity="0" />
                            </linearGradient>
                            <!-- Animated Glow Filter -->
                            <filter id="glow">
                                <feGaussianBlur stdDeviation="6" result="coloredBlur"/>
                                <feMerge>
                                    <feMergeNode in="coloredBlur"/>
                                    <feMergeNode in="SourceGraphic"/>
                                </feMerge>
                            </filter>
                        </defs>
                        
                        <!-- Grid Lines -->
                        <path d="M0,50 L400,50 M0,100 L400,100 M0,150 L400,150" stroke="#334155" stroke-dasharray="4" stroke-width="1" />
                        
                        <!-- Area Fill with draw animation via clipPath -->
                        <clipPath id="chartClip">
                           <rect x="0" y="0" width="0" height="200">
                               <animate attributeName="width" from="0" to="400" dur="2.5s" fill="freeze" calcMode="spline" keySplines="0.4 0 0.2 1" />
                           </rect>
                        </clipPath>
                        
                        <g clip-path="url(#chartClip)">
                            <!-- The Fill -->
                            <path d="M0,180 Q50,160 100,170 T200,120 T300,80 T400,40 L400,200 L0,200 Z" fill="url(#gradientFill)" />
                            <!-- The Line Graph -->
                            <path d="M0,180 Q50,160 100,170 T200,120 T300,80 T400,40" fill="none" stroke="url(#gradientLine)" stroke-width="4" stroke-linecap="round" filter="url(#glow)" />
                            
                            <!-- Data Points -->
                            <circle cx="100" cy="170" r="4" fill="#0F172A" stroke="#3B82F6" stroke-width="2" />
                            <circle cx="200" cy="120" r="5" fill="#0F172A" stroke="#10B981" stroke-width="3" />
                            <circle cx="300" cy="80" r="5" fill="#0F172A" stroke="#10B981" stroke-width="3" />
                            
                            <!-- Final Target Point -->
                            <circle cx="400" cy="40" r="6" fill="#34D399" />
                            <circle cx="400" cy="40" r="14" fill="none" stroke="#34D399" stroke-width="2" stroke-dasharray="4,4">
                                <animateTransform attributeName="transform" type="rotate" from="0 400 40" to="360 400 40" dur="4s" repeatCount="indefinite" />
                            </circle>
                        </g>
                    </svg>

                    <!-- Animated Particles rising -->
                    <div class="absolute bottom-0 left-1/4 w-1.5 h-1.5 bg-blue-400 rounded-full animate-ping" style="animation-duration: 3s; animation-delay: 1s;"></div>
                    <div class="absolute bottom-10 left-1/2 w-2 h-2 bg-emerald-400 rounded-full animate-ping" style="animation-duration: 4s; animation-delay: 0.5s;"></div>
                    <div class="absolute bottom-5 right-1/4 w-1.5 h-1.5 bg-blue-300 rounded-full animate-ping" style="animation-duration: 2.5s; animation-delay: 2s;"></div>
                </div>
            </div>

            <!-- Floating Elements -->
            <div class="absolute -right-8 top-1/4 bg-slate-900 border border-slate-700 p-4 rounded-xl shadow-[0_10px_30px_rgba(0,0,0,0.5)] z-20 animate-[bounce_4s_infinite]">
                <p class="text-xs text-slate-400 mb-1 font-medium tracking-wide">Monthly Rent</p>
                <p class="text-base font-bold text-emerald-400">+EGP 2,450</p>
            </div>
            
            <div class="absolute -left-6 bottom-1/4 bg-slate-900 border border-slate-700 p-3 rounded-lg shadow-xl z-20 animate-[bounce_3.5s_infinite_0.5s]">
                <div class="flex items-center gap-2">
                    <div class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></div>
                    <p class="text-xs font-semibold text-white">Dividend Paid</p>
                </div>
            </div>
        </div>
      </div>

    </div>
  </div>
</section>
