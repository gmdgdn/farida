---
// PropertyCard.astro
export interface Props {
  title: string;
  location: string;
  image: string;
  irr: string;
  funded: number;
  investors: number;
  highlight?: string;
}

const { title, location, image, irr, funded, investors, highlight } = Astro.props;
---

<div class="group relative bg-white rounded-2xl border border-slate-200 overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1">
  <!-- Image Container -->
  <div class="relative h-56 overflow-hidden">
    <!-- Gradient overlay for text legibility -->
    <div class="absolute inset-0 bg-gradient-to-t from-slate-900/60 to-transparent z-10"></div>
    
    <!-- Property image (will zoom on hover) -->
    <img src={image} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 ease-out" loading="lazy" />
    
    <!-- Optional highlight badge -->
    {highlight && (
      <div class="absolute top-4 left-4 z-20">
        <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-semibold bg-white/95 text-farida-primary shadow-sm backdrop-blur-sm">
          {highlight}
        </span>
      </div>
    )}

    <!-- Location overlay -->
    <div class="absolute bottom-4 left-4 z-20 flex items-center text-white/90">
      <svg class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
      <span class="text-sm font-medium">{location}</span>
    </div>
  </div>

  <!-- Content -->
  <div class="p-6">
    <h3 class="font-serif text-xl font-bold text-slate-900 mb-4 line-clamp-1">{title}</h3>
    
    <!-- Key Metrics Grid -->
    <div class="grid grid-cols-2 gap-4 mb-6">
      <div class="bg-slate-50 p-3 rounded-lg border border-slate-100">
        <p class="text-xs text-slate-500 font-medium mb-1 uppercase tracking-wider">Target IRR</p>
        <p class="text-lg font-bold text-farida-green">{irr}</p>
      </div>
      <div class="bg-slate-50 p-3 rounded-lg border border-slate-100">
        <p class="text-xs text-slate-500 font-medium mb-1 uppercase tracking-wider">Investors</p>
        <p class="text-lg font-bold text-slate-900">{investors.toLocaleString()}</p>
      </div>
    </div>

    <!-- Funding Progress Bar -->
    <div class="mb-6">
      <div class="flex justify-between text-sm mb-2">
        <span class="font-medium text-slate-700">Funding Progress</span>
        <span class="font-bold text-farida-primary">{funded}%</span>
      </div>
      <div class="w-full bg-slate-100 rounded-full h-2.5 overflow-hidden">
        <div class="bg-farida-primary h-2.5 rounded-full transition-all duration-1000" style={`width: ${funded}%`}></div>
      </div>
    </div>

    <!-- Call to Action -->
    <a href={`/properties/${title.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`} class="block w-full py-3 px-4 border border-farida-primary text-center text-sm font-semibold rounded-lg text-farida-primary hover:bg-farida-primary hover:text-white transition-colors duration-200">
      View Property
    </a>
  </div>
</div>
