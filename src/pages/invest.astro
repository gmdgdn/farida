---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import PropertyCard from '../components/PropertyCard.astro';
import Footer from '../components/Footer.astro';

const properties = [
  {
    title: "Time Tower Hotel Suites",
    location: "CBD, New Administrative Capital",
    image: "https://images.unsplash.com/photo-1582719508461-905c673771fd?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80",
    irr: "14.5%",
    funded: 85,
    investors: 1240,
    highlight: "High Yield"
  },
  {
    title: "Al-Rehab Commercial Hub",
    location: "New Cairo, Cairo",
    image: "https://images.unsplash.com/photo-1519420573924-65fcd45245f8?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80",
    irr: "12.0%",
    funded: 100,
    investors: 850,
    highlight: "Fully Funded"
  },
  {
    title: "Zayed Residential Complex",
    location: "Sheikh Zayed, Giza",
    image: "https://images.unsplash.com/photo-1600585154340-be6161a56a0c?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80",
    irr: "11.2%",
    funded: 42,
    investors: 315
  },
  {
    title: "Maadi Corniche Lofts",
    location: "Maadi, Cairo",
    image: "https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80",
    irr: "10.5%",
    funded: 20,
    investors: 110,
    highlight: "New Listing"
  },
  {
    title: "Soma Bay Beachfront Villa",
    location: "Red Sea, Egypt",
    image: "https://images.unsplash.com/photo-1613490908677-2f88dd315d19?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80",
    irr: "15.0%",
    funded: 60,
    investors: 420
  },
  {
    title: "Fifth Settlement Retail Front",
    location: "New Cairo, Cairo",
    image: "https://images.unsplash.com/photo-1567401893414-76b7b1e5a7a5?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80",
    irr: "13.2%",
    funded: 95,
    investors: 890
  }
];
---

<Layout title="Invest | Farida.estate">
  <Header />
  
  <main class="pt-32 pb-24 bg-slate-50 min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Page Header -->
      <div class="mb-12">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-100/50 border border-blue-200 text-farida-accent text-sm font-medium mb-4">
          <span class="flex h-2 w-2 rounded-full bg-farida-accent"></span>
          Live Offerings
        </div>
        <h1 class="text-4xl md:text-5xl font-serif font-bold text-slate-900 mb-4 tracking-tight">Available Properties</h1>
        <p class="text-xl text-slate-600 max-w-2xl">
          Build your diverse real estate portfolio layer by layer. Explore institutional-grade properties selected for optimal yield and growth.
        </p>
      </div>

      <!-- Filters (Mock) -->
      <div class="flex flex-wrap gap-3 mb-10 pb-6 border-b border-slate-200">
        <button class="px-5 py-2 rounded-full bg-slate-900 text-white text-sm font-medium shadow-md">All Properties</button>
        <button class="px-5 py-2 rounded-full bg-white border border-slate-300 text-slate-700 text-sm font-medium hover:bg-slate-50 transition-colors">Commercial</button>
        <button class="px-5 py-2 rounded-full bg-white border border-slate-300 text-slate-700 text-sm font-medium hover:bg-slate-50 transition-colors">Residential</button>
        <button class="px-5 py-2 rounded-full bg-white border border-slate-300 text-slate-700 text-sm font-medium hover:bg-slate-50 transition-colors">Hospitality</button>
      </div>

      <!-- Property Grid -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {properties.map(property => (
          <PropertyCard {...property} />
        ))}
      </div>
      
    </div>
  </main>
  
  <Footer />
</Layout>
