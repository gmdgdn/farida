---
// Footer.astro
---

<footer class="bg-slate-900 border-t border-slate-800 pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 lg:gap-8 mb-12">
      
      <!-- Brand & Mission -->
      <div class="md:col-span-1 border-r border-slate-800 pr-8">
        <a href="/" class="flex items-center gap-2 group mb-6">
          <svg class="h-8 w-8 text-white group-hover:text-farida-accent transition-colors" viewBox="0 0 24 24" fill="currentColor">
            <path d="M4 10h3v7H4zM10.5 10h3v7h-3zM2 19h20v3H2zM17 10h3v7h-3zM12 1L2 6v2h20V6z" />
          </svg>
          <span class="font-serif font-bold text-2xl text-white tracking-tight">FARIDA</span>
        </a>
        <p class="text-slate-400 text-sm leading-relaxed">
          Democratizing prime Egyptian real estate. Build wealth through fractional ownership, regulated by the FRA and managed by industry experts.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h4 class="text-white font-semibold mb-6 tracking-wide">Invest</h4>
        <ul class="space-y-4">
          <li><a href="/invest" class="text-slate-400 hover:text-white transition-colors text-sm">All Properties</a></li>
          <li><a href="/invest/residential" class="text-slate-400 hover:text-white transition-colors text-sm">Residential</a></li>
          <li><a href="/invest/commercial" class="text-slate-400 hover:text-white transition-colors text-sm">Commercial</a></li>
          <li><a href="/secondary-market" class="text-slate-400 hover:text-white transition-colors text-sm">Secondary Market <span class="bg-farida-accent/20 text-farida-accent text-[10px] px-2 py-0.5 rounded-full ml-1 font-bold">NEW</span></a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-white font-semibold mb-6 tracking-wide">Company</h4>
        <ul class="space-y-4">
          <li><a href="/about" class="text-slate-400 hover:text-white transition-colors text-sm">About Us</a></li>
          <li><a href="/news" class="text-slate-400 hover:text-white transition-colors text-sm">News & Insights</a></li>
          <li><a href="/faq" class="text-slate-400 hover:text-white transition-colors text-sm">Help & FAQ</a></li>
          <li><a href="/contact" class="text-slate-400 hover:text-white transition-colors text-sm">Contact Support</a></li>
        </ul>
      </div>

      <!-- Compliance & App -->
      <div>
        <h4 class="text-white font-semibold mb-6 tracking-wide">Get the App</h4>
        <div class="flex flex-col gap-3">
          <a href="#" class="inline-flex items-center gap-2 bg-slate-800 hover:bg-slate-700 border border-slate-700 transition-colors rounded-lg px-4 py-2 w-full max-w-[160px]">
            <svg class="h-6 w-6 text-white" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.04 2.26-.74 3.73-.78 1.45 0 2.53.56 3.23 1.34-1.8.96-2.22 3.12-1 4.54 1.14 1.32 3.04 1.61 3.86 1.48-1.57 3.55-3.05 3.81-4.9 5.59zm-3.66-14.4c.18-1.54-.6-2.98-1.63-3.88-1.12-1-2.6-1.55-3.8-1.28-.27 1.63.78 3.15 1.76 4.05 1.05.97 2.65 1.43 3.67 1.11z"/>
            </svg>
            <div class="text-left">
              <span class="block text-[10px] text-slate-400 leading-none mb-0.5">Download on the</span>
              <span class="block text-sm font-semibold text-white leading-none">App Store</span>
            </div>
          </a>
          <a href="#" class="inline-flex items-center gap-2 bg-slate-800 hover:bg-slate-700 border border-slate-700 transition-colors rounded-lg px-4 py-2 w-full max-w-[160px]">
            <svg class="h-6 w-6 text-white" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.523 15.3414c-.5511 0-1.0968-.2156-1.5178-.6366l-4.4168-4.417 4.4168-4.417c.421-.421.9667-.6365 1.5178-.6365s1.0967.2155 1.5178.6365l4.3312 4.3313c.8344.8344.8344 2.1868 0 3.0211l-4.3312 4.3313c-.4211.421-9667.6366-1.5178.6366zM2.8532 21.6568c-.463 0-.9238-.178-1.2755-.5298-.7005-.7005-.7005-1.8386 0-2.539L6.108 14.0578l4.4168 4.417-4.5303 4.5303c-.876.876-2.2654.876-3.1413 0zm5.1186-9.1416l-4.4168-4.417 4.5304-4.5302c.3517-.3518.8125-.5297 1.2755-.5297s.9238.1779 1.2755.5297l4.5302 4.5302-4.4168 4.417zM9.5442 12.0152l4.417 4.4168-4.417 4.417-4.4168-4.417 4.4168-4.4168z"/>
            </svg>
            <div class="text-left">
              <span class="block text-[10px] text-slate-400 leading-none mb-0.5">GET IT ON</span>
              <span class="block text-sm font-semibold text-white leading-none">Google Play</span>
            </div>
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="pt-8 border-t border-slate-800 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-slate-500 text-sm">© {new Date().getFullYear()} Farida.estate. All rights reserved.</p>
      <div class="flex gap-6">
        <a href="/terms" class="text-slate-500 hover:text-white text-sm transition-colors">Terms</a>
        <a href="/privacy" class="text-slate-500 hover:text-white text-sm transition-colors">Privacy</a>
        <a href="/sharia" class="text-slate-500 hover:text-white text-sm transition-colors">Shari'a Compliance</a>
      </div>
    </div>
  </div>
</footer>
